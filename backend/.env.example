DATABASE_URL="postgresql://crm_user:crm_password@localhost:5433/crm_db"
FRONTEND_URL="http://localhost:5173"
JWT_SECRET="change_this_secret_in_production"
PORT=3000

# ── Cloudflare R2 file storage ────────────────────────────────────────────────
# All five vars must be set for R2 to be active.
# When any is missing the app falls back to local disk (dev-only).
#
# R2_ACCOUNT_ID      — Cloudflare account ID (found in the R2 dashboard URL)
# R2_ACCESS_KEY_ID   — R2 API token → "Manage R2 API Tokens" → Access Key ID
# R2_SECRET_ACCESS_KEY — Same token → Secret Access Key
# R2_BUCKET_NAME     — Name of the R2 bucket (e.g. "crm-files")
# R2_PUBLIC_URL      — Public URL for the bucket, no trailing slash
#                      Enable "Public access" in the bucket settings to get this.
#                      Or use a custom domain via Cloudflare.
#
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="crm-files"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"
