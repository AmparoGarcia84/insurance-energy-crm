generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workdays      Workday[]
  assignedTasks Task[]
  documents     Document[]
  activities    Activity[]
}

// ── Client ────────────────────────────────────────────────────────────────────

enum AddressType {
  FISCAL
  BUSINESS
  PERSONAL
}

enum AccountType {
  PERSONAL
  BUSINESS
  CLIENTS
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
  COMPANY
  COMMUNITY_OF_OWNERS
  SELF_EMPLOYED
  PENSIONER
  RETIRED
  COLLABORATOR
  PROSPECT
  OTHER
  SUPPLIER
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  LOST
  PROSPECTING
  PAYMENT_DEFAULT
  HIGH_CLAIMS
}

enum ClientQualification {
  NEW_BUSINESS
  PORTFOLIO
  REFERRED_CLIENT
  BNI_REFERRAL
  MARKETING_SOCIAL_MEDIA
  MARKET_LOSS
  PROJECT_CANCELLED
  CANCELLED
  NOT_PROFITABLE
  PAYMENT_DEFAULT
}

enum CollectionManager {
  INSURANCE_COMPANY
  BANK_TRANSFER
  BROKER
  CARD_PAYMENT
  UNPAID
}

model Client {
  id           String  @id @default(uuid())

  // Identificación
  clientNumber String? @unique
  name         String
  nif          String? @unique

  // Clasificación
  type              ClientType?
  status            ClientStatus?
  qualification     ClientQualification?
  activity          String?              // valores de ClientActivity (domain-types)
  sector            String?              // valores de ClientSector (domain-types)
  collectionManager CollectionManager?

  // Fechas / documentos
  birthDate               DateTime? @db.Date
  drivingLicenseIssueDate DateTime? @db.Date
  dniExpiryDate           DateTime? @db.Date

  // Contacto
  mobilePhone    String?
  secondaryPhone String?
  website        String?

  // Empresa
  employees     Int?
  annualRevenue Float?
  sicCode       String?

  // Gestión comercial
  accountOwnerUserId    String?
  accountOwnerName      String?
  commercialAgentUserId String?
  commercialAgentName   String?

  // Relaciones
  addresses    ClientAddress[]
  bankAccounts ClientBankAccount[]
  emails       ClientEmail[]

  // Jerarquía
  isMainClient Boolean  @default(false)
  mainClientId String?
  mainClient   Client?  @relation("ClientHierarchy", fields: [mainClientId], references: [id])
  subClients   Client[] @relation("ClientHierarchy")

  // Observaciones
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies        Policy[]
  energyContracts EnergyContract[]
  cases           Case[]
  sales           Sale[]
  tasks           Task[]
  documents       Document[]
  activities      Activity[]
}

model ClientAddress {
  id         String      @id @default(uuid())
  clientId   String
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       AddressType
  street     String?
  postalCode String?
  city       String?
  province   String?
  country    String?
}

model ClientBankAccount {
  id       String      @id @default(uuid())
  clientId String
  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     AccountType
  iban     String
}

model ClientEmail {
  id         String  @id @default(uuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  address    String
  isPrimary  Boolean @default(false)
  label      String?
  labelColor String?
}

// ── Sale ──────────────────────────────────────────────────────────────────────

enum SaleType {
  INSURANCE
  ENERGY
}

enum SaleBusinessType {
  NEW_BUSINESS
  EXISTING_BUSINESS
}

enum SaleProjectSource {
  NONE
  NOTICE
  COLD_CALL
  EMPLOYEE_REFERRAL
  EXTERNAL_REFERRAL
  PARTNER
  ONLINE_STORE
  PUBLIC_RELATIONS
  TRADE_SHOW
  SALES_EMAIL_ALIAS
  SEMINAR_PARTNER
  INTERNAL_SEMINAR
  WEB_DOWNLOAD
  WEB_RESEARCH
  CHAT
}

enum SaleForecastCategory {
  CHANNEL
  BEST_CASE
  CONFIRMED
}

enum InsuranceSaleStage {
  RESPONSE_PENDING
  DOCUMENTS_PENDING
  SIGNATURE_PENDING
  ISSUANCE_PENDING
  BILLING_THIS_MONTH
  BILLING_NEXT_MONTH
  RECURRENT_BILLING
  INVOICE_PENDING_PAYMENT
  WRONG_SETTLEMENT
  BILLED_AND_PAID
  CANCELED_UNPAID
  NOT_INSURABLE
  KO_SCORING
  LOST
}

enum EnergySaleStage {
  RESPONSE_PENDING
  DOCUMENTS_PENDING
  SIGNATURE_PENDING
  ACTIVATION_PENDING
  BILLING_THIS_MONTH
  BILLED_AND_PAID
  LOST
}

model Sale {
  id           String    @id @default(uuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  clientName   String?

  type         SaleType
  businessType SaleBusinessType?
  title        String
  companyName  String?
  insuranceBranch String?

  insuranceStage  InsuranceSaleStage?
  energyStage     EnergySaleStage?

  amount               Float?
  expectedRevenue      Float?
  expectedSavingsPerYear Float?
  probabilityPercent   Float?
  forecastCategory     SaleForecastCategory?

  expectedCloseDate DateTime? @db.Date
  issueDate         DateTime? @db.Date
  billingDate       DateTime? @db.Date

  projectSource  SaleProjectSource?
  channel        String?
  campaignSource String?
  socialLeadId   String?

  ownerUserId   String?
  ownerUserName String?
  contactName   String?

  policyNumber String?
  contractId   String?

  nextStep    String?
  lostReason  String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases      Case[]
  tasks      Task[]
  documents  Document[]
  activities Activity[]

  @@index([clientId])
}

// ── Policy ────────────────────────────────────────────────────────────────────

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

model Policy {
  id           String       @id @default(uuid())
  clientId     String
  client       Client       @relation(fields: [clientId], references: [id])
  policyNumber String?
  insurer      String
  product      String
  status       PolicyStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  premium      Float?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([clientId])
}

// ── EnergyContract ────────────────────────────────────────────────────────────

enum EnergyContractStatus {
  ACTIVE
  CANCELLED
  PENDING
  EXPIRED
}

model EnergyContract {
  id        String               @id @default(uuid())
  clientId  String
  client    Client               @relation(fields: [clientId], references: [id])
  supplier  String
  cups      String?
  status    EnergyContractStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([clientId])
}

// ── Case ──────────────────────────────────────────────────────────────────────

enum CaseStatus {
  NEW
  ON_HOLD
  FORWARDED
  IN_PROGRESS
  CLOSED
}

enum CasePriority {
  HIGH
  NORMAL
  LOW
}

enum CaseType {
  CLAIM
  WRONG_SETTLEMENT
  COVERAGE_DENIAL
  DATA_CHANGE
  QUERY
  OTHER
}

model Case {
  id          String       @id @default(uuid())

  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])

  // Sale is optional; when set, clientId is derived from sale.clientId
  saleId      String?
  sale        Sale?        @relation(fields: [saleId], references: [id])

  name         String      // max 200 — enforced at app layer
  occurrenceAt DateTime?
  description  String?     // max 2000
  cause        String?     // max 1000

  type         CaseType?
  status       CaseStatus   @default(NEW)
  priority     CasePriority @default(NORMAL)

  // Assigned supplier — only relevant when type = WRONG_SETTLEMENT
  supplierId   String?
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tasks      Task[]
  activities Activity[]

  @@index([clientId])
  @@index([saleId])
  @@index([supplierId])
}

// ── Supplier ──────────────────────────────────────────────────────────────────

model Supplier {
  id             String            @id @default(uuid())
  name           String
  cif            String?           @unique
  phone          String?
  secondaryPhone String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  addresses     SupplierAddress[]
  emails        SupplierEmail[]
  tasks         Task[] @relation("TaskSupplierAssoc")
  providerTasks Task[] @relation("TaskProviderSupplier")
  cases         Case[]
}

model SupplierAddress {
  id         String      @id @default(uuid())
  supplierId String
  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type       AddressType @default(FISCAL)
  street     String?
  postalCode String?
  city       String?
  province   String?
  country    String?
}

model SupplierEmail {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  address    String
  isPrimary  Boolean  @default(false)
  label      String?
  labelColor String?
}

// ── Collaborator ──────────────────────────────────────────────────────────────

model Collaborator {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Workday ───────────────────────────────────────────────────────────────────

model Workday {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  date     DateTime  @db.Date
  clockIn  DateTime?
  clockOut DateTime?
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adjustmentRequests WorkAdjustmentRequest[]

  @@index([userId, date])
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkAdjustmentRequest {
  id                String           @id @default(uuid())
  workdayId         String
  workday           Workday          @relation(fields: [workdayId], references: [id])
  reason            String
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  status            AdjustmentStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ── Document ──────────────────────────────────────────────────────────────────

enum DocumentGroup {
  INSURANCE
  ENERGY
}

enum DocumentType {
  INVOICE
  CONTRACT
  PROJECT
  DOCUMENTATION
  POLICY
}

enum DocumentStatus {
  PENDING_SIGNATURE
  EXPIRED
  UPDATED
  UNDER_REVIEW
}

model Document {
  id           String         @id @default(uuid())
  name         String
  group        DocumentGroup?
  documentType DocumentType
  status       DocumentStatus @default(PENDING_SIGNATURE)
  includedAt   DateTime       @default(now())
  expiryDate   DateTime?      @db.Date
  fileUrl      String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id])

  uploadedByUserId String?
  uploadedBy       User?   @relation(fields: [uploadedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ── Task ──────────────────────────────────────────────────────────────────────

enum TaskStatus {
  NOT_STARTED
  DEFERRED
  IN_PROGRESS
  COMPLETED
  WAITING_FOR_INPUT
  UNLOGGED
}

enum TaskPriority {
  LOWEST
  LOW
  NORMAL
  HIGH
  HIGHEST
}

enum TaskContextType {
  PROJECT
  CONTACT
}

enum ReminderChannel {
  EMAIL
  IN_APP
}

enum ReminderRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Task {
  id      String @id @default(uuid())

  subject     String
  description String?

  status      TaskStatus      @default(NOT_STARTED)
  priority    TaskPriority?
  contextType TaskContextType?

  dueDate DateTime? @db.Date

  // Assignment
  assignedToUserId String?
  assignedTo       User?   @relation(fields: [assignedToUserId], references: [id])

  // Hierarchy: task can be linked at any level — client only, client+sale, or client+sale+case.
  // When caseId is set, saleId and clientId are auto-populated from the case hierarchy.
  // When saleId is set (no case), clientId is auto-populated from the sale.
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  // Supplier: optional FK to a Supplier record (for tasks owned by a supplier)
  supplierId String?
  supplier   Supplier? @relation("TaskSupplierAssoc", fields: [supplierId], references: [id], onDelete: SetNull)

  // Provider: registered supplier that will execute this task
  providerSupplierId String?
  providerSupplier   Supplier? @relation("TaskProviderSupplier", fields: [providerSupplierId], references: [id], onDelete: SetNull)

  // Reminder (stored inline — no separate table needed at this stage)
  hasReminder        Boolean            @default(false)
  reminderAt         DateTime?
  reminderChannel    ReminderChannel?
  reminderRecurrence ReminderRecurrence?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToUserId])
  @@index([clientId])
  @@index([saleId])
  @@index([caseId])
  @@index([supplierId])
  @@index([providerSupplierId])
  @@index([dueDate])
}

// ── Activity ──────────────────────────────────────────────────────────────────

enum ActivityType {
  // User-facing interaction types
  CALL
  EMAIL
  WHATSAPP_NOTE
  MEETING
  // System event types (audit trail / ActivityLog)
  STAGE_CHANGED
  DOC_UPLOADED
  EXPORT
  CREATED
  UPDATED
}

enum ActivityDirection {
  INBOUND
  OUTBOUND
}

model Activity {
  id      String @id @default(uuid())

  userId   String
  user     User   @relation(fields: [userId], references: [id])

  // clientId is always required; saleId and caseId are optional.
  // When caseId is set, saleId and clientId are auto-populated from the case hierarchy.
  // When saleId is set (no case), clientId is auto-populated from the sale.
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  type        ActivityType
  direction   ActivityDirection?
  subject     String
  description String?
  outcome     String?
  nextStep    String?
  activityAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([saleId])
  @@index([caseId])
  @@index([userId])
  @@index([activityAt])
}
