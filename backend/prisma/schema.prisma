generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workdays Workday[]
}

// ── Client ────────────────────────────────────────────────────────────────────

enum AddressType {
  FISCAL
  BUSINESS
  PERSONAL
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
  COMPANY
  COMMUNITY_OF_OWNERS
  SELF_EMPLOYED
  PENSIONER
  RETIRED
  COLLABORATOR
  PROSPECT
  OTHER
  SUPPLIER
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  LOST
  PROSPECTING
  PAYMENT_DEFAULT
  HIGH_CLAIMS
}

enum ClientQualification {
  NEW_BUSINESS
  PORTFOLIO
  REFERRED_CLIENT
  BNI_REFERRAL
  MARKETING_SOCIAL_MEDIA
  MARKET_LOSS
  PROJECT_CANCELLED
  CANCELLED
  NOT_PROFITABLE
  PAYMENT_DEFAULT
}

enum CollectionManager {
  INSURANCE_COMPANY
  BANK_TRANSFER
  BROKER
  CARD_PAYMENT
  UNPAID
}

model Client {
  id           String  @id @default(uuid())

  // Identificación
  clientNumber String? @unique
  name         String
  nif          String? @unique

  // Clasificación
  type              ClientType?
  status            ClientStatus?
  qualification     ClientQualification?
  activity          String?              // valores de ClientActivity (domain-types)
  sector            String?              // valores de ClientSector (domain-types)
  collectionManager CollectionManager?

  // Fechas / documentos
  birthDate               DateTime? @db.Date
  drivingLicenseIssueDate DateTime? @db.Date
  dniExpiryDate           DateTime? @db.Date

  // Contacto
  mobilePhone    String?
  secondaryPhone String?
  email          String?
  website        String?

  // Empresa
  employees     Int?
  annualRevenue Float?
  sicCode       String?

  // Gestión comercial
  accountOwnerUserId    String?
  commercialAgentUserId String?

  // Relaciones
  addresses    ClientAddress[]
  bankAccounts ClientBankAccount[]

  // Jerarquía
  isMainClient Boolean  @default(false)
  mainClientId String?
  mainClient   Client?  @relation("ClientHierarchy", fields: [mainClientId], references: [id])
  subClients   Client[] @relation("ClientHierarchy")

  // Observaciones
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies        Policy[]
  energyContracts EnergyContract[]
  cases           Case[]
  sales           Sale[]
}

model ClientAddress {
  id         String      @id @default(uuid())
  clientId   String
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       AddressType
  street     String?
  postalCode String?
  city       String?
  province   String?
  country    String?
}

model ClientBankAccount {
  id       String      @id @default(uuid())
  clientId String
  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     AccountType
  iban     String
}

// ── Sale ──────────────────────────────────────────────────────────────────────

enum SaleStatus {
  OPEN
  WON
  LOST
  CANCELLED
}

model Sale {
  id       String     @id @default(uuid())
  clientId String
  client   Client     @relation(fields: [clientId], references: [id])
  title    String
  status   SaleStatus @default(OPEN)
  amount   Float?
  notes    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ── Policy ────────────────────────────────────────────────────────────────────

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

model Policy {
  id           String       @id @default(uuid())
  clientId     String
  client       Client       @relation(fields: [clientId], references: [id])
  policyNumber String?
  insurer      String
  product      String
  status       PolicyStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  premium      Float?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ── EnergyContract ────────────────────────────────────────────────────────────

enum EnergyContractStatus {
  ACTIVE
  CANCELLED
  PENDING
  EXPIRED
}

model EnergyContract {
  id        String               @id @default(uuid())
  clientId  String
  client    Client               @relation(fields: [clientId], references: [id])
  supplier  String
  cups      String?
  status    EnergyContractStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

// ── Case ──────────────────────────────────────────────────────────────────────

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Case {
  id          String     @id @default(uuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id])
  title       String
  description String?
  status      CaseStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ── Workday ───────────────────────────────────────────────────────────────────

model Workday {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  date     DateTime  @db.Date
  clockIn  DateTime?
  clockOut DateTime?
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adjustmentRequests WorkAdjustmentRequest[]
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkAdjustmentRequest {
  id                String           @id @default(uuid())
  workdayId         String
  workday           Workday          @relation(fields: [workdayId], references: [id])
  reason            String
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  status            AdjustmentStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}
