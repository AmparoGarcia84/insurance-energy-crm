generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workdays      Workday[]
  assignedTasks Task[]
  documents     Document[]
}

// ── Client ────────────────────────────────────────────────────────────────────

enum AddressType {
  FISCAL
  BUSINESS
  PERSONAL
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
  COMPANY
  COMMUNITY_OF_OWNERS
  SELF_EMPLOYED
  PENSIONER
  RETIRED
  COLLABORATOR
  PROSPECT
  OTHER
  SUPPLIER
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  LOST
  PROSPECTING
  PAYMENT_DEFAULT
  HIGH_CLAIMS
}

enum ClientQualification {
  NEW_BUSINESS
  PORTFOLIO
  REFERRED_CLIENT
  BNI_REFERRAL
  MARKETING_SOCIAL_MEDIA
  MARKET_LOSS
  PROJECT_CANCELLED
  CANCELLED
  NOT_PROFITABLE
  PAYMENT_DEFAULT
}

enum CollectionManager {
  INSURANCE_COMPANY
  BANK_TRANSFER
  BROKER
  CARD_PAYMENT
  UNPAID
}

model Client {
  id           String  @id @default(uuid())

  // Identificación
  clientNumber String? @unique
  name         String
  nif          String? @unique

  // Clasificación
  type              ClientType?
  status            ClientStatus?
  qualification     ClientQualification?
  activity          String?              // valores de ClientActivity (domain-types)
  sector            String?              // valores de ClientSector (domain-types)
  collectionManager CollectionManager?

  // Fechas / documentos
  birthDate               DateTime? @db.Date
  drivingLicenseIssueDate DateTime? @db.Date
  dniExpiryDate           DateTime? @db.Date

  // Contacto
  mobilePhone    String?
  secondaryPhone String?
  email          String?
  website        String?

  // Empresa
  employees     Int?
  annualRevenue Float?
  sicCode       String?

  // Gestión comercial
  accountOwnerUserId    String?
  accountOwnerName      String?
  commercialAgentUserId String?
  commercialAgentName   String?

  // Relaciones
  addresses    ClientAddress[]
  bankAccounts ClientBankAccount[]

  // Jerarquía
  isMainClient Boolean  @default(false)
  mainClientId String?
  mainClient   Client?  @relation("ClientHierarchy", fields: [mainClientId], references: [id])
  subClients   Client[] @relation("ClientHierarchy")

  // Observaciones
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies        Policy[]
  energyContracts EnergyContract[]
  cases           Case[]
  sales           Sale[]
  tasks           Task[]
  documents       Document[]
}

model ClientAddress {
  id         String      @id @default(uuid())
  clientId   String
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       AddressType
  street     String?
  postalCode String?
  city       String?
  province   String?
  country    String?
}

model ClientBankAccount {
  id       String      @id @default(uuid())
  clientId String
  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     AccountType
  iban     String
}

// ── Sale ──────────────────────────────────────────────────────────────────────

enum SaleType {
  INSURANCE
  ENERGY
}

enum SaleBusinessType {
  NEW_BUSINESS
  EXISTING_BUSINESS
}

enum SaleProjectSource {
  NONE
  NOTICE
  COLD_CALL
  EMPLOYEE_REFERRAL
  EXTERNAL_REFERRAL
  PARTNER
  ONLINE_STORE
  PUBLIC_RELATIONS
  TRADE_SHOW
  SALES_EMAIL_ALIAS
  SEMINAR_PARTNER
  INTERNAL_SEMINAR
  WEB_DOWNLOAD
  WEB_RESEARCH
  CHAT
}

enum SaleForecastCategory {
  CHANNEL
  BEST_CASE
  CONFIRMED
}

enum InsuranceSaleStage {
  RESPONSE_PENDING
  DOCUMENTS_PENDING
  SIGNATURE_PENDING
  ISSUANCE_PENDING
  BILLING_THIS_MONTH
  BILLING_NEXT_MONTH
  RECURRENT_BILLING
  INVOICE_PENDING_PAYMENT
  WRONG_SETTLEMENT
  BILLED_AND_PAID
  CANCELED_UNPAID
  NOT_INSURABLE
  KO_SCORING
  LOST
}

enum EnergySaleStage {
  RESPONSE_PENDING
  DOCUMENTS_PENDING
  SIGNATURE_PENDING
  ACTIVATION_PENDING
  BILLING_THIS_MONTH
  BILLED_AND_PAID
  LOST
}

model Sale {
  id           String    @id @default(uuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  clientName   String?

  type         SaleType
  businessType SaleBusinessType?
  title        String
  companyName  String?
  insuranceBranch String?

  insuranceStage  InsuranceSaleStage?
  energyStage     EnergySaleStage?

  amount               Float?
  expectedRevenue      Float?
  expectedSavingsPerYear Float?
  probabilityPercent   Float?
  forecastCategory     SaleForecastCategory?

  expectedCloseDate DateTime? @db.Date
  issueDate         DateTime? @db.Date
  billingDate       DateTime? @db.Date

  projectSource  SaleProjectSource?
  channel        String?
  campaignSource String?
  socialLeadId   String?

  ownerUserId   String?
  ownerUserName String?
  contactName   String?

  policyNumber String?
  contractId   String?

  nextStep    String?
  lostReason  String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

// ── Policy ────────────────────────────────────────────────────────────────────

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

model Policy {
  id           String       @id @default(uuid())
  clientId     String
  client       Client       @relation(fields: [clientId], references: [id])
  policyNumber String?
  insurer      String
  product      String
  status       PolicyStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  premium      Float?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ── EnergyContract ────────────────────────────────────────────────────────────

enum EnergyContractStatus {
  ACTIVE
  CANCELLED
  PENDING
  EXPIRED
}

model EnergyContract {
  id        String               @id @default(uuid())
  clientId  String
  client    Client               @relation(fields: [clientId], references: [id])
  supplier  String
  cups      String?
  status    EnergyContractStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

// ── Case ──────────────────────────────────────────────────────────────────────

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Case {
  id          String     @id @default(uuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id])
  title       String
  description String?
  status      CaseStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ── Collaborator ──────────────────────────────────────────────────────────────

model Collaborator {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Workday ───────────────────────────────────────────────────────────────────

model Workday {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  date     DateTime  @db.Date
  clockIn  DateTime?
  clockOut DateTime?
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adjustmentRequests WorkAdjustmentRequest[]
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkAdjustmentRequest {
  id                String           @id @default(uuid())
  workdayId         String
  workday           Workday          @relation(fields: [workdayId], references: [id])
  reason            String
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  status            AdjustmentStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ── Document ──────────────────────────────────────────────────────────────────

enum DocumentGroup {
  INSURANCE
  ENERGY
}

enum DocumentType {
  INVOICE
  CONTRACT
  PROJECT
  DOCUMENTATION
  POLICY
}

enum DocumentStatus {
  PENDING_SIGNATURE
  EXPIRED
  UPDATED
  UNDER_REVIEW
}

model Document {
  id           String         @id @default(uuid())
  name         String
  group        DocumentGroup?
  documentType DocumentType
  status       DocumentStatus @default(PENDING_SIGNATURE)
  includedAt   DateTime       @default(now())
  expiryDate   DateTime?      @db.Date
  fileUrl      String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id])

  uploadedByUserId String?
  uploadedBy       User?   @relation(fields: [uploadedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Task ──────────────────────────────────────────────────────────────────────

enum TaskStatus {
  NOT_STARTED
  DEFERRED
  IN_PROGRESS
  COMPLETED
  WAITING_FOR_INPUT
  UNLOGGED
}

enum TaskPriority {
  LOWEST
  LOW
  NORMAL
  HIGH
  HIGHEST
}

enum TaskContextType {
  PROJECT
  CONTACT
}

enum RelatedEntityType {
  CLIENT
  SALE
  QUOTE
  PROJECT
  SALES_ORDER
  PURCHASE_ORDER
  INVOICE
  CAMPAIGN
  SUPPLIER
  CASE
  CONTRACT
  PERSONAL_DATA
}

enum ReminderChannel {
  EMAIL
  IN_APP
}

enum ReminderRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Task {
  id      String @id @default(uuid())

  subject     String
  description String?

  status      TaskStatus      @default(NOT_STARTED)
  priority    TaskPriority?
  contextType TaskContextType?

  // Polymorphic relation at application level
  relatedEntityType RelatedEntityType?
  relatedEntityId   String?

  dueDate DateTime? @db.Date

  // Assignment
  assignedToUserId String?
  assignedTo       User?   @relation(fields: [assignedToUserId], references: [id])

  // Optional client link
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // Reminder (stored inline — no separate table needed at this stage)
  hasReminder        Boolean            @default(false)
  reminderAt         DateTime?
  reminderChannel    ReminderChannel?
  reminderRecurrence ReminderRecurrence?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
