{
  "name": "crm-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:fresh": "sh dev-fresh.sh",
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend & wait",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "jsdom": "^29.0.1"
  }
}
